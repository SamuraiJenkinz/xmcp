# Atlas Exchange Infrastructure - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Flask
# ──────────────────────────────────────────────
# Generate a production key with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-change-in-prod

# ──────────────────────────────────────────────
# Azure AD SSO + Graph API (from your App Registration)
# Used for both SSO login and Microsoft Graph colleague lookup.
# App registration requires: User.Read.All, ProfilePhoto.Read.All
# (application permissions with admin consent)
# ──────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ──────────────────────────────────────────────
# Azure OpenAI
# ──────────────────────────────────────────────
CHATGPT_ENDPOINT=https://stg1.mmc-dallas-int-non-prod-ingress.mgti.mmc.com/coreapi/openai/v1/deployments/mmc-tech-gpt-4o-mini-128k-2024-07-18/chat/completions
AZURE_OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Exchange Auth (CBA - for unattended/production)
# Omit these for interactive browser-based auth
# ──────────────────────────────────────────────
# AZURE_CERT_THUMBPRINT=
# AZURE_TENANT_DOMAIN=mmc.onmicrosoft.com

# ──────────────────────────────────────────────
# Feedback Analytics (MCP)
# ──────────────────────────────────────────────
# ATLAS_DB_PATH — Path to the Atlas SQLite database (same file as CHAT_DB_PATH).
# Required for feedback analytics MCP tools (get_feedback_summary, get_low_rated_responses).
ATLAS_DB_PATH=

# ──────────────────────────────────────────────
# Optional overrides
# ──────────────────────────────────────────────
# CHAT_HOST=0.0.0.0
# CHAT_PORT=5000
# CHAT_DB_PATH=../chat.db
# SESSION_FILE_DIR=/tmp/flask-sessions
# API_VERSION=2023-05-15
# OPENAI_MODEL=mmc-tech-gpt-4o-mini-128k-2024-07-18
