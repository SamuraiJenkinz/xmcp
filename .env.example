# Exchange Online PowerShell authentication
#
# Auth mode is auto-detected:
#   - If AZURE_CERT_THUMBPRINT is set → certificate-based auth (CBA, unattended)
#   - Otherwise → interactive auth (browser popup for login)
#
# For development: leave these blank/unset → interactive auth will be used.
# For production: set all three for unattended certificate-based auth.

# Certificate-based auth (optional — set all three for CBA mode)
AZURE_CERT_THUMBPRINT=   # Certificate thumbprint from Azure AD app registration
AZURE_CLIENT_ID=         # Application (client) ID from Azure AD
AZURE_TENANT_DOMAIN=     # Primary tenant domain (e.g., contoso.onmicrosoft.com)
